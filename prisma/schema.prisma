generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  username        String           @unique
  password        String?
  isAdmin         Boolean          @default(false)
  createdAt       DateTime         @default(now())
  userSimulations UserSimulation[]
  weakPoints      WeakPoint[]
}

model Capitolo {
  id        Int        @id
  code      String     @unique
  name      String
  nEsame    Int
  questions Question[]
}

model Question {
  id         String      @id @default(cuid())
  capitoloId Int
  capitolo   Capitolo    @relation(fields: [capitoloId], references: [id])
  text       String      @unique
  risposta   Boolean
  image      String?
  answers    Answer[]
  weakPoints WeakPoint[]
}

model Simulation {
  id              String           @id @default(cuid())
  number          Int              @unique
  questions       String
  capitoloCode    String?
  titolo          String?
  userSimulations UserSimulation[]
}

model UserSimulation {
  id             String          @id @default(cuid())
  userId         String
  simulationId   String
  status         String          @default("IN_PROGRESS")
  score          Int?
  errors         Int?
  passed         Boolean?
  timeElapsed    Int?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  questionOrder  String?
  user           User            @relation(fields: [userId], references: [id])
  simulation     Simulation      @relation(fields: [simulationId], references: [id])
  answers        Answer[]
  capitoloResults CapitoloResult[]
}

model Answer {
  id               String         @id @default(cuid())
  userSimulationId String
  questionId       String
  userAnswer       Boolean?
  isCorrect        Boolean?
  answeredAt       DateTime?
  userSimulation   UserSimulation @relation(fields: [userSimulationId], references: [id])
  question         Question       @relation(fields: [questionId], references: [id])

  @@unique([userSimulationId, questionId])
}

model CapitoloResult {
  id               String         @id @default(cuid())
  userSimulationId String
  capitoloCode     String
  correct          Int
  total            Int
  accuracy         Float
  userSimulation   UserSimulation @relation(fields: [userSimulationId], references: [id])
}

model WeakPoint {
  id                  String   @id @default(cuid())
  userId              String
  questionId          String
  consecutiveCorrect  Int      @default(0)
  totalAttempts       Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id])
  question            Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}
